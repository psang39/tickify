  .dark .text-gray-400,
  .dark .text-slate-400,
  .dark .text-zinc-400,
  .dark .text-neutral-400 {
    color: #94a3b8 !important;
  }

  .dark [class~="placeholder:text-gray-400"]::placeholder,
  .dark [class~="placeholder:text-slate-400"]::placeholder,
  .dark [class~="placeholder:text-gray-500"]::placeholder,
  .dark [class~="placeholder:text-slate-500"]::placeholder {
