  .dark [class~="bg-[#F8F7FF]"],
  .dark [class~="bg-[#F9FAFB]"],
  .dark [class~="bg-[#FAFAFA]"],
  .dark [class~="bg-[#FFF5FB]"],
  .dark [class~="bg-[#fff5fb]"],
  .dark [class~="bg-[#FDF2F8]"],
  .dark [class~="bg-[#fdf2f8]"] {
